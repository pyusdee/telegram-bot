/**
 * Send Telegram Message via Vercel
 *
 * @param string $chatId Telegram chat ID
 * @param string $message Message text (supports HTML)
 * @param array $options Additional options (not used currently)
 * @return bool Success status
 */
function sendTelegramMessage($chatId, $message, $options = []) {
    $data = [
        'chat_id' => $chatId,
        'message' => $message
    ];

    $ch = curl_init(TELEGRAM_VERCEL_URL);
    curl_setopt($ch, CURLOPT_RETURNTRANSFER, true);
    curl_setopt($ch, CURLOPT_POST, true);
    curl_setopt($ch, CURLOPT_POSTFIELDS, json_encode($data));
    curl_setopt($ch, CURLOPT_HTTPHEADER, ['Content-Type: application/json']);

    $result = curl_exec($ch);
    $httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);

    // Log the attempt
    $status = ($httpCode == 200) ? 'SUCCESS' : 'FAILED (HTTP ' . $httpCode . ')';
    error_log(date('[Y-m-d H:i:s] ') . "Telegram to Chat ID: $chatId | Status: $status\n", 3, __DIR__ . '/telegram_logs.txt');

    return $httpCode == 200;
}

